---
import Sonner from "@/core/components/atoms/Sonner.astro"
import Styles from "@/core/components/atoms/Styles.astro"
import { ClientRouter } from "astro:transitions"
import { pwaAssetsHead } from "virtual:pwa-assets/head"
import { pwaInfo } from "virtual:pwa-info"

// Context
interface Props {
  title?: string
}

const { title } = Astro.props
const finalTitle = title
  ? `${title} | Student Statistics`
  : "Student Statistics"
---

<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <title>{finalTitle}</title>

    <meta name="robots" content="noindex, nofollow" />

    {
      pwaAssetsHead.themeColor && (
        <>
          <meta name="theme-color" content={pwaAssetsHead.themeColor.content} />
          <meta
            name="msapplication-TileColor"
            content={pwaAssetsHead.themeColor.content}
          />
        </>
      )
    }

    <meta name="msapplication-TileImage" content="/pwa-150x150.png" />
    {pwaAssetsHead.links.map((link) => <link {...link} />)}

    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

    {/* Styles */}
    <Styles />

    {/* Scripts */}
    <Sonner />
    <script src="@/core/scripts/pwa.ts"></script>
    <script src="@/core/scripts/zod.ts"></script>

    <ClientRouter />
  </head>

  <body class="w-full">
    <slot />
  </body>
</html>
