---
import { TbChevronRight } from "react-icons/tb"

// Context
interface Props {
  page: number
  totalPages: number
}

const { page, totalPages } = Astro.props

// Pagination
function pageUrl(pageNumber: number) {
  const url = new URL(Astro.url)
  url.searchParams.set("page", pageNumber.toString())

  return url.pathname + url.search + url.hash
}

// - Previous page
const previousPage = page - 1
const hasPreviousPage = page > 1

const previousPageUrl = pageUrl(previousPage)

// - Next page
const nextPage = page + 1
const hasNextPage = nextPage <= totalPages

const nextPageUrl = pageUrl(nextPage)

// - Pages to display
const isOverflowAtStart = page > 3 && totalPages > 5
const isOverflowAtEnd = page < totalPages - 2 && totalPages > 5
const pages = []

if (isOverflowAtStart && isOverflowAtEnd) {
  pages.push(page - 1, page, page + 1)
} else if (isOverflowAtStart) {
  pages.push(totalPages - 3, totalPages - 2, totalPages - 1, totalPages)
} else if (isOverflowAtEnd) {
  pages.push(1, 2, 3, 4)
} else {
  pages.push(...Array.from({ length: totalPages }, (_, i) => i + 1))
}

// First and last href
const firstPageUrl = pageUrl(1)
const lastPageUrl = pageUrl(totalPages)
---

<nav>
  <ul class="flex items-center justify-center">
    <li style={{ viewTransitionName: "pagination-previous" }}>
      <a
        {...hasPreviousPage
          ? { href: previousPageUrl }
          : { "aria-disabled": "true", tabindex: "-1" }}
        class:list={[
          {
            "brightness-50": !hasPreviousPage,
          },
        ]}
      >
        <span class="sr-only">Página anterior</span>
        <TbChevronRight className="size-5 rotate-180" />
      </a>
    </li>

    {
      isOverflowAtStart && (
        <>
          <li style={{ viewTransitionName: "pagination-first" }}>
            <a href={firstPageUrl}>1</a>
          </li>
          <li>
            <span class="pagination-overflow">...</span>
          </li>
        </>
      )
    }

    {
      pages.map((pageNumber) => {
        // Check if the page number is active
        const isActive = pageNumber === page

        // URL for the page
        const url = pageUrl(pageNumber)

        // Transition name
        let viewTransitionName: string | undefined

        if (pageNumber === 1) viewTransitionName = "pagination-first"
        else if (pageNumber === totalPages)
          viewTransitionName = "pagination-last"
        else viewTransitionName = `pagination-${pageNumber}`

        return (
          <li
            class:list={[
              {
                "bg-card rounded-full": isActive,
              },
            ]}
            style={{ viewTransitionName }}
          >
            {isActive ? (
              <span aria-current="page">{pageNumber}</span>
            ) : (
              <a href={url}>{pageNumber}</a>
            )}
          </li>
        )
      })
    }

    {
      isOverflowAtEnd && (
        <>
          <li>
            <span class="pagination-overflow">...</span>
          </li>
          <li style={{ viewTransitionName: "pagination-last" }}>
            <a href={lastPageUrl}>{totalPages}</a>
          </li>
        </>
      )
    }

    <li style={{ viewTransitionName: "pagination-next" }}>
      <a
        {...hasNextPage
          ? { href: nextPageUrl }
          : { "aria-disabled": "true", tabindex: "-1" }}
        class:list={[
          {
            "brightness-50": !hasNextPage,
          },
        ]}
      >
        <TbChevronRight className="size-5" />
        <span class="sr-only">Página siguiente</span>
      </a>
    </li>
  </ul>
</nav>

<style>
  @reference "@styles";

  a,
  span,
  li > .pagination-overflow {
    @apply flex size-8 items-center justify-center;
  }

  li > .pagination-overflow {
    @apply px-3;
  }
</style>
