---
import { db } from "@/core/database"
import HomeLayout from "@/core/layout/HomeLayout.astro"
import {
  OrderQuery,
  PageQuery,
  SearchQuery,
} from "@/core/validation/query-validation"
import SemesterMainSection from "@/semester/components/sections/SemesterMainSection.astro"
import { semesterTable } from "@/semester/schema/semester-schema"
import { asc, count, desc, sql } from "drizzle-orm"
import { TbBookmark } from "react-icons/tb"

// Constants
const PAGE_LIMIT = 12

// Context
const { searchParams } = Astro.url
const { user } = Astro.locals

// Query parameters
let [{ data: page = 1 }, { data: q }, { data: orderQuery }] = await Promise.all(
  [
    PageQuery.safeParseAsync(searchParams.get("page")),
    SearchQuery.safeParseAsync(searchParams.get("q")),
    OrderQuery.safeParseAsync(searchParams.get("order")),
  ]
)

// Count all semesters
const totalSemesters = await db
  .select({ count: count() })
  .from(semesterTable)
  .where(
    sql`${semesterTable.name} like ${`%${q ?? ""}%`} and ${semesterTable.userId} = ${user.id}`
  )

const { count: totalCount } = totalSemesters[0] ?? { count: 0 }
const totalPages = Math.ceil(totalCount / PAGE_LIMIT)

// Verify if page is a valid number
if (totalPages > 0 && page > totalPages) {
  page = 1
  searchParams.set("page", page.toString())

  return Astro.redirect(Astro.url.toString(), 302)
}

// Search the semesters
const semesters = await db
  .select()
  .from(semesterTable)
  .where(
    sql`${semesterTable.name} like ${`%${q ?? ""}%`} and ${semesterTable.userId} = ${user.id}`
  )
  .orderBy(
    orderQuery === "asc" ? asc(semesterTable.name) : desc(semesterTable.name)
  )
  .limit(PAGE_LIMIT)
  .offset((page - 1) * PAGE_LIMIT)
---

<HomeLayout title="Ciclos">
  <header class="flex items-center gap-2">
    <TbBookmark className="size-7" />

    <h1 class="inline text-2xl font-bold">Ciclos</h1>
  </header>

  <div role="none" class="bg-muted my-4 h-px"></div>

  <SemesterMainSection {semesters} {page} {totalPages} {q} {orderQuery} />
</HomeLayout>
