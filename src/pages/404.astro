---
import { Link } from "@/core/components/ui/link"
import HomeLayout from "@/core/layout/HomeLayout.astro"
import Layout from "@/core/layout/Layout.astro"
import { tw } from "@/core/lib/tailwind"

// Context
const hasAuth = !!Astro.cookies.get("token")
const ContextLayout = hasAuth ? HomeLayout : Layout

const linkText = hasAuth ? "Volver al inicio" : "Volver al login"
const linkHref = hasAuth ? "/" : "/login"

// Styles
const sectionClassname = hasAuth ? tw`min-h-full` : tw`min-h-svh`
---

<ContextLayout title="¡Ups!">
  <section
    class:list={[
      "mx-auto flex min-h-full max-w-82 flex-col items-center justify-center gap-6 px-5 py-8",
      sectionClassname,
    ]}
  >
    <h1 class="text-5xl font-bold">¡Ups!</h1>
    <p class="text-muted-foreground text-pretty">
      La página que buscas no existe o ha sido movida. Por favor, verifica la
      URL e intenta nuevamente.
    </p>

    <Link variant="default" href={linkHref} className="w-full">{linkText}</Link>
  </section>
</ContextLayout>
